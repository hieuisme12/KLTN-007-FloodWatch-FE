# Sao chép thành `.env` hoặc `.env.local` (không commit file chứa giá trị thật).

# URL backend — không hiển thị trực tiếp trên UI người dùng cuối
VITE_API_BASE_URL=https://api.example.com

# Mapbox (public token — vẫn không log ra console hay DOM)
VITE_MAPBOX_TOKEN=
# Hoặc:
# VITE_MAPBOX_ACCESS_TOKEN=

# Tuỳ chọn: geocode proxy paths nếu BE dùng route khác mặc định
# VITE_REVERSE_GEOCODE_PATH=
# VITE_GEOCODE_SEARCH_PATH=
# VITE_GEOCODE_PLACE_PATH=
# VITE_GEOCODE_FORWARD_PATH=

# Tuỳ chọn: Google OAuth redirect (nếu dùng)
# VITE_GOOGLE_AUTH_START_URL=
