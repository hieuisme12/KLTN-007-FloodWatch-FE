# API Backend (optional). Auth: access JWT + refresh + session_token — FE tự refresh khi 401.
VITE_API_BASE_URL=https://api.floodsight.id.vn
# VITE_API_BASE_URL=http://localhost:3000

# Đường dẫn reverse geocode trên BE (mặc định /api/v1/geocode/reverse?lat=&lng=)
# VITE_REVERSE_GEOCODE_PATH=/api/v1/geocode/reverse

# Geocode công khai (mount trước JWT): gợi ý / chi tiết / chuỗi đầy đủ
# VITE_GEOCODE_SEARCH_PATH=/api/v1/geocode/search
# VITE_GEOCODE_PLACE_PATH=/api/v1/geocode/place
# VITE_GEOCODE_FORWARD_PATH=/api/v1/geocode/forward
# Tương thích: VITE_FORWARD_GEOCODE_PATH trỏ tới /forward (trước đây có thể dùng cho endpoint geocode forward)
# VITE_FORWARD_GEOCODE_PATH=/api/v1/geocode/forward

# Mapbox - Public token for client-side maps (get one at https://account.mapbox.com/)
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here
# Optional compatibility key (some environments name it this way)
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_public_token_here

# Google OAuth — URL BE bắt đầu redirect (mặc định = VITE_API_BASE_URL + /api/v1/auth/google)
# VITE_GOOGLE_AUTH_START_URL=https://api.floodsight.id.vn/api/v1/auth/google
# Chỉ khi dùng Google Identity Services trên FE (không bắt buộc với luồng redirect qua BE):
# VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com